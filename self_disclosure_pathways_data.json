  "forward_rules": [
    { "rule_id": "R_SHAME_01", "target_y": "Depth > Core > Shame", "type": "supportive", "x": ["private", "dyadic"], "m": ["reduced fear of judgment"], "strength": "high", "rationale": "Private one-to-one interaction strongly supports shame disclosure because anticipated negative evaluation is reduced." },
    { "rule_id": "R_SHAME_02", "target_y": "Depth > Core > Shame", "type": "supportive", "x": ["empathy: high", "safety: high"], "m": ["perceived nonjudgment"], "strength": "high", "rationale": "High perceived empathy and safety strongly support shame disclosure by making vulnerable self-revelation feel less threatening." },
    { "rule_id": "R_SHAME_03", "target_y": "Depth > Core > Shame", "type": "supportive", "x": ["anonymity", "text"], "m": ["disinhibition"], "strength": "moderate", "rationale": "Anonymous text interaction can facilitate shame disclosure by lowering social exposure and increasing disinhibition." },
    { "rule_id": "R_SHAME_04", "target_y": "Depth > Core > Shame", "type": "inhibitory", "x": ["public", "group"], "m": ["fear of judgment", "reputational concern"], "strength": "high", "rationale": "Public group settings strongly inhibit shame disclosure because social and reputational costs are high." },
    { "rule_id": "R_TRAUMA_01", "target_y": "Depth > Core > Trauma", "type": "supportive", "x": ["therapeutic", "private", "established relationship"], "m": ["trust", "relational safety"], "strength": "high", "rationale": "Trauma disclosure is strongly supported in private therapeutic or trusted settings where the discloser feels safe enough to reveal highly vulnerable content." },
    { "rule_id": "R_TRAUMA_02", "target_y": "Depth > Core > Trauma", "type": "supportive", "x": ["repeated", "responsiveness: high"], "m": ["relational safety", "trust"], "strength": "moderate", "rationale": "Repeated responsive interaction can support trauma disclosure as trust and relational safety accumulate." },
    { "rule_id": "R_TRAUMA_03", "target_y": "Depth > Core > Trauma", "type": "supportive", "x": ["private", "continuity: high", "one-to-one"], "m": ["relational safety"], "strength": "moderate", "rationale": "Private, continuous one-to-one interaction can support trauma disclosure when the interaction feels stable and safe over time." },
    { "rule_id": "R_TRAUMA_04", "target_y": "Depth > Core > Trauma", "type": "inhibitory", "x": ["one-off", "stranger"], "m": ["low trust"], "strength": "high", "rationale": "Trauma disclosure is strongly inhibited in one-off interactions with strangers because the trust required for extreme vulnerability is missing." },
    { "rule_id": "R_IDBELIEF_01", "target_y": "Depth > Core > Identity-Defining Beliefs", "type": "supportive", "x": ["established relationship", "supportive", "dyadic"], "m": ["trust", "relational safety"], "strength": "high", "rationale": "Disclosure of identity-defining beliefs is strongly supported in supportive one-to-one established relationships." },
    { "rule_id": "R_IDBELIEF_02", "target_y": "Depth > Core > Identity-Defining Beliefs", "type": "supportive", "x": ["continuity: high", "understanding: high"], "m": ["perceived continuity"], "strength": "moderate", "rationale": "Perceived continuity and understanding can support disclosure of identity-defining beliefs by making the receiver seem stable and comprehending." },
    { "rule_id": "R_IDBELIEF_03", "target_y": "Depth > Core > Identity-Defining Beliefs", "type": "inhibitory", "x": ["public", "adversarial"], "m": ["self-protection"], "strength": "high", "rationale": "Identity-defining beliefs are strongly inhibited in public or adversarial settings because the discloser protects the self from exposure or challenge." },
    { "rule_id": "R_AMOUNT_HIGH_01", "target_y": "Amount > High", "type": "supportive", "x": ["repeated", "continuity: high", "responsiveness: high"], "m": ["accessibility", "habit formation"], "strength": "high", "rationale": "High disclosure volume is strongly supported when interaction is recurrent, continuous, and responsive." },
    { "rule_id": "R_AMOUNT_HIGH_02", "target_y": "Amount > High", "type": "supportive", "x": ["private", "safety: high"], "m": ["reduced fear of judgment"], "strength": "moderate", "rationale": "Disclosure amount may increase when the setting is private and feels safe." },
    { "rule_id": "R_AMOUNT_HIGH_03", "target_y": "Amount > High", "type": "supportive", "x": ["loneliness: high", "companionship seeking: high"], "m": ["emotional relief seeking"], "strength": "moderate", "rationale": "High disclosure amount may occur when a lonely user repeatedly turns to disclosure for companionship or emotional relief." },
    { "rule_id": "R_AMOUNT_HIGH_04", "target_y": "Amount > High", "type": "inhibitory", "x": ["formal", "time-limited"], "m": ["constraint"], "strength": "high", "rationale": "High disclosure amount is less likely when interaction is short or normatively constrained." },
    { "rule_id": "R_AMOUNT_LOW_01", "target_y": "Amount > Low", "type": "supportive", "x": ["public", "one-to-many", "broadcast"], "m": ["self-monitoring", "impression management"], "strength": "high", "rationale": "Low disclosure amount is supported when communication is public, broadcast-oriented, and visible to many others." },
    { "rule_id": "R_AMOUNT_LOW_02", "target_y": "Amount > Low", "type": "supportive", "x": ["stranger", "one-off"], "m": ["low trust"], "strength": "moderate", "rationale": "Disclosure amount may remain low in interactions lacking relational history or trust." },
    { "rule_id": "R_NEGVAL_01", "target_y": "Valence > Negative", "type": "supportive", "x": ["loneliness: high"], "m": ["emotional relief seeking"], "strength": "moderate", "rationale": "Negative-valence disclosure may become more likely when lonely individuals use disclosure as a way to offload distress." },
    { "rule_id": "R_NEGVAL_02", "target_y": "Valence > Negative", "type": "supportive", "x": ["private", "fear of judgment: low", "empathy: high"], "m": ["perceived nonjudgment"], "strength": "high", "rationale": "Private low-judgment interaction with an empathic receiver strongly supports negative-valence disclosure." },
    { "rule_id": "R_NEGVAL_03", "target_y": "Valence > Negative", "type": "inhibitory", "x": ["public", "persistence: high", "reputational cost: high"], "m": ["impression management"], "strength": "high", "rationale": "Negative-valence disclosure is often suppressed in public persistent settings because users anticipate reputational consequences." },
    { "rule_id": "R_POSVAL_01", "target_y": "Valence > Positive", "type": "supportive", "x": ["public", "persistence: high", "one-to-many"], "m": ["impression management"], "strength": "high", "rationale": "Positive-valence disclosure is favored in public persistent settings because users curate how they are seen by others." },
    { "rule_id": "R_POSVAL_02", "target_y": "Valence > Positive", "type": "supportive", "x": ["broadcast"], "m": ["self-presentation"], "strength": "moderate", "rationale": "Broadcast-oriented disclosure often tilts positive because the interaction is more performative and less suited to vulnerable negative material." },
    { "rule_id": "R_DELIB_01", "target_y": "Intentionality > Deliberate", "type": "supportive", "x": ["asynchronous", "persistence: high"], "m": ["editability", "self-monitoring"], "strength": "high", "rationale": "Disclosure is more likely to be deliberate when the channel allows composing, editing, and reviewing before sending." },
    { "rule_id": "R_DELIB_02", "target_y": "Intentionality > Deliberate", "type": "supportive", "x": ["public", "broadcast"], "m": ["impression management"], "strength": "high", "rationale": "Public broadcast settings tend to increase deliberate disclosure because the speaker becomes more strategic about what to reveal." },
    { "rule_id": "R_SPONT_01", "target_y": "Intentionality > Spontaneous", "type": "supportive", "x": ["synchronous", "dyadic", "dialogue"], "m": ["immediacy"], "strength": "high", "rationale": "Synchronous dyadic dialogue promotes spontaneous disclosure because there is less time for editing and more conversational flow." },
    { "rule_id": "R_SPONT_02", "target_y": "Intentionality > Spontaneous", "type": "supportive", "x": ["emotional arousal: high"], "m": ["reduced self-monitoring"], "strength": "moderate", "rationale": "When emotional activation is high, disclosure may become less controlled and more spontaneous." },
    { "rule_id": "R_EMOSTATE_01", "target_y": "Content Type > Emotional States", "type": "supportive", "x": ["private", "supportive", "empathy: high"], "m": ["emotional safety"], "strength": "high", "rationale": "Emotional-state disclosure is strongly supported when the receiver is supportive, empathic, and the interaction is private." },
    { "rule_id": "R_EMOSTATE_02", "target_y": "Content Type > Emotional States", "type": "supportive", "x": ["one-to-one", "responsiveness: high", "continuity: high"], "m": ["availability"], "strength": "moderate", "rationale": "Emotional-state disclosure may increase when interaction is one-to-one, responsive, and continuous." },
    { "rule_id": "R_REFLECT_01", "target_y": "Content Type > Reflective", "type": "supportive", "x": ["asynchronous", "text"], "m": ["editability", "self-reflection"], "strength": "high", "rationale": "Reflective disclosure is strongly supported in asynchronous text settings because they allow more time to think through and articulate meaning." },
    { "rule_id": "R_REFLECT_02", "target_y": "Content Type > Reflective", "type": "supportive", "x": ["continuity: high", "repeated", "dialogue"], "m": ["guided reflection"], "strength": "moderate", "rationale": "Repeated dialogic interaction with continuity can support reflective disclosure by prompting self-explanation over time." },
    { "rule_id": "R_FASTESC_01", "target_y": "Temporal Progression > Pace > Fast", "type": "supportive", "x": ["anonymity", "text"], "m": ["disinhibition"], "strength": "moderate", "rationale": "Fast escalation into intimate disclosure may occur in anonymous text interaction because disinhibition reduces the usual pacing constraints." },
    { "rule_id": "R_FASTESC_02", "target_y": "Temporal Progression > Pace > Fast", "type": "supportive", "x": ["private", "fear of judgment: low", "responsiveness: high"], "m": ["reduced fear of judgment", "accessibility"], "strength": "high", "rationale": "Disclosure may deepen quickly when the interaction is private, low-judgment, and responsive." },
    { "rule_id": "R_SLOWESC_01", "target_y": "Temporal Progression > Pace > Slow", "type": "supportive", "x": ["stranger", "face-to-face", "initial encounter"], "m": ["caution", "uncertainty management"], "strength": "high", "rationale": "Escalation is likely to remain slow in face-to-face interaction with strangers at the start of a relationship." },
    { "rule_id": "R_SLOWESC_02", "target_y": "Temporal Progression > Pace > Slow", "type": "supportive", "x": ["public", "one-to-many"], "m": ["self-monitoring"], "strength": "moderate", "rationale": "Public one-to-many communication can slow escalation because disclosure becomes more monitored and selective." },
    { "rule_id": "R_BREADTH_HIGH_01", "target_y": "Breadth > High", "type": "supportive", "x": ["private", "repeated", "continuity: high", "one-to-one"], "m": ["accessibility", "habit formation"], "strength": "high", "rationale": "Breadth tends to be high when a private one-to-one relationship is recurrent and continuous enough to invite disclosure across many topics." },
    { "rule_id": "R_BREADTH_HIGH_02", "target_y": "Breadth > High", "type": "supportive", "x": ["dialogue", "responsiveness: high", "supportive"], "m": ["reciprocity", "availability"], "strength": "moderate", "rationale": "Responsive supportive dialogue can broaden the range of topics that feel discussable." },
    { "rule_id": "R_BREADTH_MED_01", "target_y": "Breadth > Medium", "type": "supportive", "x": ["private", "dyadic", "dialogue"], "m": ["trust"], "strength": "moderate", "rationale": "A private dyadic dialogue supports moderate topical breadth even when disclosure does not yet extend across many areas." },
    { "rule_id": "R_BREADTH_LOW_01", "target_y": "Breadth > Low", "type": "supportive", "x": ["public", "one-to-many", "broadcast"], "m": ["self-monitoring", "impression management"], "strength": "high", "rationale": "Breadth is often low in public broadcast settings because people narrow what they reveal to protect how they are seen." },
    { "rule_id": "R_BREADTH_LOW_02", "target_y": "Breadth > Low", "type": "supportive", "x": ["stranger", "one-off"], "m": ["caution", "low trust"], "strength": "moderate", "rationale": "Breadth stays low when the partner is a stranger and there is no relational future to justify broad disclosure." },
    { "rule_id": "R_BIOFACTS_01", "target_y": "Depth > Peripheral > Biographical Facts", "type": "supportive", "x": ["initial encounter", "stranger", "dialogue"], "m": ["uncertainty management"], "strength": "high", "rationale": "Biographical facts are a common early disclosure target because they help others orient to who the speaker is without much vulnerability." },
    { "rule_id": "R_BIOFACTS_02", "target_y": "Depth > Peripheral > Biographical Facts", "type": "supportive", "x": ["public", "broadcast"], "m": ["self-presentation"], "strength": "moderate", "rationale": "Public self-presentation often includes basic biographical information because it is identity-relevant but still relatively safe." },
    { "rule_id": "R_SURFPREF_01", "target_y": "Depth > Peripheral > Surface Preferences", "type": "supportive", "x": ["casual", "dialogue", "dyadic"], "m": ["reciprocity"], "strength": "moderate", "rationale": "Surface preferences are easy to exchange in casual conversation because they help sustain reciprocal talk without much risk." },
    { "rule_id": "R_SURFPREF_02", "target_y": "Depth > Peripheral > Surface Preferences", "type": "supportive", "x": ["public", "broadcast"], "m": ["self-presentation"], "strength": "moderate", "rationale": "Preference statements are often used in broadcast settings because they personalize the self while remaining relatively low stakes." },
    { "rule_id": "R_ROUTINE_01", "target_y": "Depth > Peripheral > Routine Information", "type": "supportive", "x": ["repeated", "continuity: high"], "m": ["availability", "habit formation"], "strength": "high", "rationale": "Routine information is especially likely in repeated continuous interaction because it becomes part of ongoing coordination and everyday check-ins." },
    { "rule_id": "R_ROUTINE_02", "target_y": "Depth > Peripheral > Routine Information", "type": "supportive", "x": ["text", "asynchronous"], "m": ["accessibility"], "strength": "moderate", "rationale": "Asynchronous text channels facilitate routine updates because they are easy to send frequently and at low cost." },
    { "rule_id": "R_ATTITUDES_01", "target_y": "Depth > Intermediate > Attitudes", "type": "supportive", "x": ["dialogue", "established relationship", "dyadic"], "m": ["trust", "reciprocity"], "strength": "high", "rationale": "Attitudes are more likely to be disclosed in established dyadic dialogue where some trust already exists." },
    { "rule_id": "R_OPINIONSDEPTH_01", "target_y": "Depth > Intermediate > Opinions", "type": "supportive", "x": ["public", "broadcast", "persistence: high"], "m": ["self-presentation", "impression management"], "strength": "moderate", "rationale": "Opinions are often disclosed in public persistent spaces because they help position the self before an audience." },
    { "rule_id": "R_OPINIONSDEPTH_02", "target_y": "Depth > Intermediate > Opinions", "type": "supportive", "x": ["dialogue", "understanding: high"], "m": ["reciprocity"], "strength": "moderate", "rationale": "When the receiver is perceived as understanding, personal opinions become easier to disclose in conversation." },
    { "rule_id": "R_PERSINT_01", "target_y": "Depth > Intermediate > Personal Interpretations", "type": "supportive", "x": ["continuity: high", "understanding: high", "dialogue"], "m": ["guided reflection", "perceived continuity"], "strength": "high", "rationale": "Personal interpretations are more likely when the interaction supports ongoing meaning-making with a receiver who seems consistent and understanding." },
    { "rule_id": "R_MODVULN_01", "target_y": "Depth > Intermediate > Moderate Vulnerabilities", "type": "supportive", "x": ["private", "empathy: high", "safety: high"], "m": ["emotional safety", "perceived nonjudgment"], "strength": "high", "rationale": "Moderate vulnerabilities are supported by private, empathic, safe settings that reduce the threat of judgment." },
    { "rule_id": "R_MODVULN_02", "target_y": "Depth > Intermediate > Moderate Vulnerabilities", "type": "inhibitory", "x": ["public", "reputational cost: high"], "m": ["self-protection"], "strength": "high", "rationale": "Moderate vulnerabilities are less likely in public settings where reputational stakes are high." },
    { "rule_id": "R_FEARS_01", "target_y": "Depth > Core > Fears", "type": "supportive", "x": ["private", "fear of judgment: low", "empathy: high"], "m": ["perceived nonjudgment"], "strength": "high", "rationale": "Disclosure of fears is supported by private empathic settings in which the receiver feels unlikely to judge." },
    { "rule_id": "R_FEARS_02", "target_y": "Depth > Core > Fears", "type": "inhibitory", "x": ["public", "group"], "m": ["fear of judgment"], "strength": "high", "rationale": "Core fears are inhibited in public group settings because anticipated judgment is too salient." },
    { "rule_id": "R_DEEPNEEDS_01", "target_y": "Depth > Core > Deep Needs", "type": "supportive", "x": ["private", "supportive", "established relationship"], "m": ["emotional safety", "trust"], "strength": "high", "rationale": "Deep needs are more likely to be disclosed in private supportive relationships where trust and safety are already present." },
    { "rule_id": "R_DEEPNEEDS_02", "target_y": "Depth > Core > Deep Needs", "type": "supportive", "x": ["continuity: high", "understanding: high"], "m": ["perceived continuity", "guided reflection"], "strength": "moderate", "rationale": "A stable and understanding receiver can support disclosure of deep needs by making the interaction feel enduring and interpretable." },
    { "rule_id": "R_AMOUNT_MED_01", "target_y": "Amount > Medium", "type": "supportive", "x": ["dyadic", "dialogue", "repeated"], "m": ["reciprocity"], "strength": "moderate", "rationale": "Medium disclosure volume is plausible in repeated dyadic dialogue where reciprocity exists but disclosure has not become especially extensive." },
    { "rule_id": "R_AMOUNT_MED_02", "target_y": "Amount > Medium", "type": "supportive", "x": ["private", "safety: medium", "fear of judgment: medium"], "m": ["trust"], "strength": "moderate", "rationale": "Medium disclosure volume often arises in settings that are somewhat safe but not fully disinhibiting." },
    { "rule_id": "R_MIXVAL_01", "target_y": "Valence > Mixed", "type": "supportive", "x": ["private", "dialogue", "established relationship"], "m": ["trust"], "strength": "moderate", "rationale": "Mixed-valence disclosure is more likely in established dialogue where people feel able to share both positive and negative material." },
    { "rule_id": "R_MIXVAL_02", "target_y": "Valence > Mixed", "type": "supportive", "x": ["continuity: high", "text", "asynchronous"], "m": ["self-reflection", "guided reflection"], "strength": "moderate", "rationale": "Reflective asynchronous exchange can produce mixed-valence disclosure because users articulate ambivalent or layered experiences." },
    { "rule_id": "R_HONEST_HIGH_01", "target_y": "Honesty / Accuracy > High", "type": "supportive", "x": ["private", "fear of judgment: low", "safety: high"], "m": ["reduced fear of judgment", "trust"], "strength": "high", "rationale": "High honesty is supported when private safe conditions reduce the need for defensive distortion." },
    { "rule_id": "R_HONEST_HIGH_02", "target_y": "Honesty / Accuracy > High", "type": "supportive", "x": ["continuity: high", "understanding: high"], "m": ["perceived continuity"], "strength": "moderate", "rationale": "A stable, understanding receiver can make truthful disclosure feel more worthwhile and less risky." },
    { "rule_id": "R_HONEST_MED_01", "target_y": "Honesty / Accuracy > Medium", "type": "supportive", "x": ["asynchronous", "fear of judgment: medium", "safety: medium"], "m": ["editability", "self-monitoring"], "strength": "moderate", "rationale": "Medium honesty can arise when people disclose with some care and some self-editing rather than being fully open or fully strategic." },
    { "rule_id": "R_HONEST_LOW_01", "target_y": "Honesty / Accuracy > Low", "type": "supportive", "x": ["public", "impression management motivation: high", "persistence: high"], "m": ["impression management", "self-presentation"], "strength": "high", "rationale": "Low honesty becomes more likely when persistent public visibility increases strategic self-presentation." },
    { "rule_id": "R_PARTUNPLANNED_01", "target_y": "Intentionality > Partly Unplanned", "type": "supportive", "x": ["synchronous", "emotional arousal: high"], "m": ["reduced self-monitoring", "immediacy"], "strength": "high", "rationale": "Partly unplanned disclosure often emerges when high arousal combines with real-time conversational flow." },
    { "rule_id": "R_PARTUNPLANNED_02", "target_y": "Intentionality > Partly Unplanned", "type": "supportive", "x": ["dialogue", "responsiveness: high"], "m": ["immediacy"], "strength": "moderate", "rationale": "Highly responsive dialogue can move disclosure into a partly unplanned mode even without complete spontaneity." },
    { "rule_id": "R_FACTS_01", "target_y": "Content Type > Facts", "type": "supportive", "x": ["initial encounter", "stranger"], "m": ["uncertainty management"], "strength": "moderate", "rationale": "Facts are common disclosure content in first encounters because they reduce uncertainty with low vulnerability." },
    { "rule_id": "R_FACTS_02", "target_y": "Content Type > Facts", "type": "supportive", "x": ["public", "broadcast"], "m": ["self-presentation"], "strength": "moderate", "rationale": "Broadcast contexts often favor factual self-description because it is legible and relatively low risk." },
    { "rule_id": "R_PREFS_01", "target_y": "Content Type > Preferences", "type": "supportive", "x": ["casual", "dialogue"], "m": ["reciprocity"], "strength": "moderate", "rationale": "Preferences are an easy reciprocal content type in casual conversation." },
    { "rule_id": "R_PREFS_02", "target_y": "Content Type > Preferences", "type": "supportive", "x": ["public", "broadcast"], "m": ["self-presentation"], "strength": "moderate", "rationale": "Preferences are often disclosed publicly because they personalize the self without requiring much vulnerability." },
    { "rule_id": "R_CT_OPINIONS_01", "target_y": "Content Type > Opinions", "type": "supportive", "x": ["public", "broadcast", "one-to-many"], "m": ["self-presentation", "impression management"], "strength": "moderate", "rationale": "Opinions are a common content type in public one-to-many contexts because they signal identity and stance." },
    { "rule_id": "R_GOALS_01", "target_y": "Content Type > Goals", "type": "supportive", "x": ["advice seeking: high", "private", "one-to-one"], "m": ["guided reflection", "trust"], "strength": "high", "rationale": "Goal disclosure is especially likely in private one-to-one settings when the user is seeking advice or direction." },
    { "rule_id": "R_NEEDS_01", "target_y": "Content Type > Needs", "type": "supportive", "x": ["private", "supportive", "empathy: high"], "m": ["emotional safety"], "strength": "high", "rationale": "Need disclosure is strongly supported when the interaction feels private, supportive, and empathic." },
    { "rule_id": "R_IDENTITY_01", "target_y": "Content Type > Identity", "type": "supportive", "x": ["continuity: high", "understanding: high", "established relationship"], "m": ["perceived continuity", "trust"], "strength": "high", "rationale": "Identity content is more likely when the receiver feels enduring and capable of understanding the self over time." },
    { "rule_id": "R_RELCONTENT_01", "target_y": "Content Type > Relational Content", "type": "supportive", "x": ["established relationship", "dyadic", "dialogue"], "m": ["reciprocity", "trust"], "strength": "high", "rationale": "Relational content is especially likely in established dyadic dialogue because the relationship itself is part of what is being negotiated." },
    { "rule_id": "R_PACEMED_01", "target_y": "Temporal Progression > Pace > Medium", "type": "supportive", "x": ["repeated", "dialogue", "dyadic"], "m": ["reciprocity"], "strength": "moderate", "rationale": "A medium pace of progression is plausible when repeated dyadic dialogue allows disclosure to deepen steadily without either sharp restraint or rapid escalation." },
    { "rule_id": "R_ESCALATING_01", "target_y": "Temporal Progression > Escalation > Escalating", "type": "supportive", "x": ["repeated", "continuity: high", "supportive"], "m": ["accessibility", "trust"], "strength": "high", "rationale": "Escalating disclosure is supported when interaction is repeated, continuous, and supportive enough for trust to accumulate." },
    { "rule_id": "R_ESCALATING_02", "target_y": "Temporal Progression > Escalation > Escalating", "type": "supportive", "x": ["private", "fear of judgment: low", "responsiveness: high"], "m": ["reduced fear of judgment", "accessibility"], "strength": "moderate", "rationale": "Low-judgment responsive interaction encourages progressive deepening rather than flat disclosure." },
    { "rule_id": "R_NONESCALATING_01", "target_y": "Temporal Progression > Escalation > Non-Escalating", "type": "supportive", "x": ["public", "broadcast", "persistence: high"], "m": ["self-monitoring", "impression management"], "strength": "high", "rationale": "Non-escalating disclosure is common in public broadcast contexts where disclosure remains managed and relatively flat." },
