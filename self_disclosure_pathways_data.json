    { "rule_id": "RR_AMOUNT_HIGH_02", "target_y": "Amount > High", "type": "supportive", "x": ["private", "safety: high"], "m": ["reduced fear of judgment"], "strength": "moderate", "rationale": "Feeling safe in a private context can increase how much someone discloses." },
